<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title bar -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:gravity="center"
            android:padding="@dimen/padding_medium"
            android:text="@string/profil_title"
            android:textColor="@color/primary"
            android:textSize="@dimen/text_xlarge"
            android:textStyle="bold" />

        <!-- Profile photo section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/padding_large">

            <FrameLayout
                android:layout_width="@dimen/profile_photo_size"
                android:layout_height="@dimen/profile_photo_size">

                <ImageView
                    android:id="@+id/ivProfilePhoto"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/circle_profile_bg"
                    android:contentDescription="Photo de profil"
                    android:scaleType="centerCrop" />
            </FrameLayout>

            <Button
                android:id="@+id/btnChangePhoto"
                style="@style/ShopMa.Button.Outline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                android:text="@string/change_photo" />
        </LinearLayout>

        <!-- Form fields -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:layout_marginTop="@dimen/margin_small"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/nom_hint"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_small" />

            <EditText
                android:id="@+id/etNom"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_background"
                android:inputType="textPersonName"
                android:paddingStart="@dimen/padding_medium"
                android:paddingEnd="@dimen/padding_medium"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                android:text="@string/email_hint"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_small" />

            <EditText
                android:id="@+id/etEmailProfil"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_background"
                android:enabled="false"
                android:inputType="textEmailAddress"
                android:paddingStart="@dimen/padding_medium"
                android:paddingEnd="@dimen/padding_medium"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                android:text="@string/adresse_hint"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_small" />

            <EditText
                android:id="@+id/etAdresse"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:layout_marginTop="4dp"
                android:background="@drawable/input_background"
                android:hint="@string/adresse_hint"
                android:inputType="textPostalAddress"
                android:paddingStart="@dimen/padding_medium"
                android:paddingEnd="@dimen/padding_medium"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_medium" />

        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/surface"
            android:layout_marginTop="@dimen/margin_small"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <Button
                android:id="@+id/btnSave"
                style="@style/ShopMa.Button.Orange"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:text="@string/btn_save" />

            <Button
                android:id="@+id/btnHistorique"
                style="@style/ShopMa.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/margin_medium"
                android:text="@string/btn_historique" />

            <Button
                android:id="@+id/btnLogout"
                style="@style/ShopMa.Button.Outline"
                android:layout_width="match_parent"
                android:layout_height="@dimen/btn_height"
                android:layout_marginTop="@dimen/margin_medium"
                android:text="@string/btn_logout" />
        </LinearLayout>

        <!-- Bottom spacer -->
        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
