<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="48dp"
    android:layout_height="48dp">

    <ImageButton
        android:id="@+id/btnCart"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_cart"
        android:tint="@color/text_on_primary"
        android:contentDescription="Panier" />

    <TextView
        android:id="@+id/tvCartBadge"
        android:layout_width="@dimen/badge_size"
        android:layout_height="@dimen/badge_size"
        android:layout_gravity="top|end"
        android:layout_marginEnd="4dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/circle_badge"
        android:gravity="center"
        android:text="0"
        android:textColor="@color/badge_text"
        android:textSize="@dimen/badge_text_size"
        android:visibility="gone" />

</FrameLayout>
